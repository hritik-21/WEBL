<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dynamic Form | SrutiW9</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <h1>Share your thoughts 🌸</h1>
        <form action="/submit" method="POST">
            <div class="field">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" placeholder="Butterfly" required>
            </div>
            <div class="field">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="4" placeholder="Say something sweet..." required></textarea>
            </div>
            <button type="submit" class="btn">Send Sparkles ✨</button>
        </form>
        <div style="margin-top: 2rem;">
            <a href="/" style="color: #666; text-decoration: none; font-size: 0.9rem;">← Back Home</a>
        </div>
    </div>
</body>

</html>